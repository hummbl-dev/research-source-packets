{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hummbl-dev/research-source-packets/schemas/research-source-packets-v0.1.json",
  "title": "Research Source Packet v0.1",
  "description": "Candidate, non-canon schema for a bounded research source packet with provenance, a source contract, and receipt requirements.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packetStatus",
    "packetManifest",
    "authority",
    "sourceContract",
    "receiptRequirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0.1",
      "description": "The packet schema version. The only compatibility boundary in v0.x."
    },
    "packetStatus": {
      "type": "string",
      "enum": ["candidate", "draft", "reviewed", "rejected", "superseded"],
      "description": "Lifecycle status of the packet. v0.1 packets are typically 'candidate'."
    },
    "packetManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "version", "scope"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable identifier for this packet within the producing namespace."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable title of the packet."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Version label for this packet (e.g. '0.1.0')."
        },
        "scope": {
          "type": "string",
          "minLength": 1,
          "description": "Short statement of what the packet covers and does not cover."
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "posture"],
      "properties": {
        "producer": {
          "type": "string",
          "minLength": 1,
          "description": "Who produced the packet (person, agent, or org identifier)."
        },
        "posture": {
          "type": "string",
          "enum": ["candidate", "non-canon", "adopted"],
          "description": "Authority posture. v0.1 packets are 'candidate' or 'non-canon'."
        },
        "orcid": {
          "type": "string",
          "description": "Optional ORCID identifier for the producer."
        }
      }
    },
    "sourceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "citation",
        "provenance",
        "evidenceGrade",
        "verificationStatus"
      ],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": [
            "journal-article",
            "preprint",
            "dataset",
            "book",
            "book-chapter",
            "conference-paper",
            "report",
            "thesis",
            "web-page",
            "other"
          ],
          "description": "The type of source being represented."
        },
        "citation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "authors", "year"],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "authors": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "year": {
              "type": "integer"
            },
            "doi": {
              "type": "string",
              "description": "Optional DOI for the source."
            },
            "url": {
              "type": "string",
              "format": "uri",
              "description": "Optional retrievable URL for the source."
            }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["origin", "capturedAt"],
          "properties": {
            "origin": {
              "type": "string",
              "minLength": 1,
              "description": "Where the source was obtained from."
            },
            "capturedAt": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp of when the source was captured into the packet."
            },
            "method": {
              "type": "string",
              "description": "Optional method of capture or transformation."
            }
          }
        },
        "evidenceGrade": {
          "type": "string",
          "enum": ["primary", "secondary", "tertiary", "uncategorized"],
          "description": "Explicit, stated grade for the type/strength of evidence."
        },
        "verificationStatus": {
          "type": "string",
          "enum": ["unverified", "self-verified", "peer-verified", "rejected"],
          "description": "Current verification state of the source contract."
        }
      }
    },
    "receiptRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["onAccept", "onReject"],
      "properties": {
        "onAccept": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "What a consumer must record when accepting the packet."
        },
        "onReject": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "What a consumer must record when rejecting the packet."
        },
        "onCite": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Optional additional requirements when citing the packet."
        }
      }
    }
  }
}
